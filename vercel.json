{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "index.js", "use": "@vercel/static" },
    { "src": "index.css", "use": "@vercel/static" },
    { "src": "widget.js", "use": "@vercel/static" },
    { "src": "leads.html", "use": "@vercel/static" },
    { "src": "test-embed.html", "use": "@vercel/static" },
    { "src": "extension/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/index.js", "dest": "index.js" },
    { "src": "/index.css", "dest": "index.css" },
    { "src": "/widget.js", "dest": "widget.js" },
    { "src": "/leads.html", "dest": "leads.html" },
    { "src": "/test-embed.html", "dest": "test-embed.html" },
    { "src": "/extension/(.*)", "dest": "extension/$1" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
